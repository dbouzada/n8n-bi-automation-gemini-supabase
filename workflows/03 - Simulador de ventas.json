    {
      "parameters": {
        "jsCode": "// Genera entre 5 y 15 ventas sintéticas por ejecución\nconst cantidadVentas = Math.floor(Math.random() * 11) + 5;\n\nconst vendedorIds = [1, 2, 3, 4, 5, 6, 7];\nconst productos = [\n  { id: 1,  precio: 1250.00 },\n  { id: 2,  precio: 950.00  },\n  { id: 3,  precio: 350.00  },\n  { id: 4,  precio: 580.00  },\n  { id: 5,  precio: 95.00   },\n  { id: 6,  precio: 65.00   },\n  { id: 7,  precio: 120.00  },\n  { id: 8,  precio: 75.00   },\n  { id: 9,  precio: 250.00  },\n  { id: 10, precio: 450.00  },\n  { id: 11, precio: 180.00  }\n];\n\n// Genera fecha aleatoria en los últimos 90 días\nfunction randomDate() {\n  const now = new Date();\n  const daysAgo = Math.floor(Math.random() * 90);\n  const hoursAgo = Math.floor(Math.random() * 24);\n  const minutesAgo = Math.floor(Math.random() * 60);\n  now.setDate(now.getDate() - daysAgo);\n  now.setHours(now.getHours() - hoursAgo);\n  now.setMinutes(now.getMinutes() - minutesAgo);\n  return now.toISOString();\n}\n\nconst ventas = [];\n\nfor (let i = 0; i < cantidadVentas; i++) {\n  const producto = productos[Math.floor(Math.random() * productos.length)];\n  const vendedor_id = vendedorIds[Math.floor(Math.random() * vendedorIds.length)];\n  const cantidad = Math.floor(Math.random() * 5) + 1;\n  const monto_total = parseFloat((producto.precio * cantidad).toFixed(2));\n\n  ventas.push({\n    json: {\n      fecha: randomDate(),\n      vendedor_id,\n      producto_id: producto.id,\n      cantidad,\n      monto_total\n    }\n  });\n}\n\nreturn ventas;"
      },
