    {
      "parameters": {
        "jsCode": "// Decide aleatoriamente si agregar un producto nuevo (20% de probabilidad)\nconst agregar = Math.random() < 0.2;\n\nif (!agregar) {\n  return [{ json: { agregar: false } }];\n}\n\nconst categorias = ['Hardware', 'Periféricos', 'Accesorios', 'Mobiliario'];\nconst nombresPorCategoria = {\n  Hardware:     ['Notebook Gamer', 'PC All-in-One', 'Servidor NAS', 'Mini PC', 'Tablet Pro'],\n  Periféricos:  ['Headset Gamer', 'Micrófono USB', 'Cámara Web 4K', 'Control RGB', 'Pad XL'],\n  Accesorios:   ['Mochila Laptop', 'Cable HDMI 2.1', 'Adaptador USB-C', 'Base Notebook', 'Limpiador LCD'],\n  Mobiliario:   ['Silla Ergonómica', 'Mesa Gamer', 'Soporte Monitor', 'Reposa Pies', 'Organizador Cables']\n};\n\nconst categoria = categorias[Math.floor(Math.random() * categorias.length)];\nconst nombres = nombresPorCategoria[categoria];\nconst nombre = nombres[Math.floor(Math.random() * nombres.length)];\n\n// Precio según categoría\nconst precioRanges = {\n  Hardware:    [500, 2000],\n  Periféricos: [50, 300],\n  Accesorios:  [15, 150],\n  Mobiliario:  [100, 800]\n};\n\nconst [min, max] = precioRanges[categoria];\nconst precio_base = parseFloat((Math.random() * (max - min) + min).toFixed(2));\n\nreturn [{ json: { agregar: true, nombre, categoria, precio_base } }];"
      },
